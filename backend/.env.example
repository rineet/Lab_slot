NODE_ENV=production
PORT=5000
MONGO_URI=
JWT_SECRET=

# URL of your deployed Vercel frontend
FRONTEND_URL=https://your-frontend.vercel.app

# Cookie settings for cross-site auth (Vercel -> Render)
COOKIE_SAME_SITE=none
COOKIE_SECURE=true

# Optional: set true only if you want backend to also serve frontend files
SERVE_FRONTEND=false

# Optional email settings
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
